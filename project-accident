<style>
:root{--bg:#020917;--bg2:#0a1628;--bg3:#0f1f38;--accent:#00d4ff;--accent2:#7c3aed;--accent3:#06ffa5;--text:#e2e8f0;--muted:#64748b;--border:rgba(0,212,255,0.15);--card:rgba(10,22,40,0.8);}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Sora',sans-serif;line-height:1.7;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,212,255,0.03)1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,0.03)1px,transparent 1px);background-size:50px 50px;pointer-events:none;z-index:0;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(2,9,23,0.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:0 40px;height:64px;display:flex;align-items:center;justify-content:space-between;}
.nav-logo{font-family:'Space Mono',monospace;color:var(--accent);font-size:16px;font-weight:700;text-decoration:none;}
.nav-logo span{color:var(--text);}
.back-btn{display:inline-flex;align-items:center;gap:8px;color:var(--muted);text-decoration:none;font-size:14px;font-weight:600;transition:color .3s;}
.back-btn:hover{color:var(--accent);}
main{position:relative;z-index:1;padding-top:64px;max-width:900px;margin:0 auto;padding-left:40px;padding-right:40px;}
.hero-section{padding:60px 0 40px;}
.project-tag-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;}
.tag{font-size:11px;font-family:'Space Mono',monospace;color:var(--accent);background:rgba(0,212,255,0.08);border:1px solid rgba(0,212,255,0.2);border-radius:4px;padding:4px 10px;letter-spacing:.05em;}
.tag.red{color:#f87171;background:rgba(248,113,113,0.08);border-color:rgba(248,113,113,0.25);}
h1{font-size:clamp(28px,4vw,48px);font-weight:700;line-height:1.15;margin-bottom:16px;}
h1 span{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.subtitle{color:var(--muted);font-size:18px;margin-bottom:32px;line-height:1.7;}
.project-img{width:100%;border-radius:16px;border:1px solid var(--border);margin:32px 0;object-fit:cover;max-height:420px;display:block;background:var(--bg3);}
.project-img-fallback{width:100%;height:300px;border-radius:16px;border:1px solid var(--border);margin:32px 0;background:linear-gradient(135deg,var(--bg3),var(--bg2));display:flex;align-items:center;justify-content:center;font-size:80px;}
.section-block{margin:48px 0;}
.section-block h2{font-size:22px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px;}
.section-block h2::before{content:'';width:4px;height:22px;background:linear-gradient(180deg,var(--accent),var(--accent2));border-radius:4px;display:block;}
p{color:var(--muted);font-size:16px;line-height:1.9;margin-bottom:16px;}
.feature-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;}
.feature-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;}
.feature-card .icon{font-size:28px;margin-bottom:10px;}
.feature-card h3{font-size:15px;font-weight:700;color:var(--text);margin-bottom:6px;}
.feature-card p{font-size:13px;margin:0;}
.tech-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:12px;}
.outcomes{display:flex;flex-direction:column;gap:12px;}
.outcome-item{display:flex;align-items:flex-start;gap:12px;padding:16px;background:var(--card);border:1px solid var(--border);border-radius:10px;}
.outcome-item i{color:var(--accent3);margin-top:2px;flex-shrink:0;}
.outcome-item span{font-size:15px;color:var(--text);}
.flow-steps{display:flex;flex-direction:column;gap:0;}
.flow-step{display:flex;gap:20px;align-items:flex-start;}
.flow-step-num{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:14px;font-weight:700;color:#000;flex-shrink:0;}
.flow-step-line{display:flex;flex-direction:column;align-items:center;gap:0;}
.flow-step-line .dot{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:14px;font-weight:700;color:#000;flex-shrink:0;}
.flow-step-line .line{width:2px;height:32px;background:linear-gradient(180deg,var(--accent2),transparent);margin:0 auto;}
.flow-content{padding:4px 0 32px;}
.flow-content h3{font-size:16px;font-weight:700;color:var(--text);margin-bottom:4px;}
.flow-content p{font-size:14px;margin:0;}
.cta-row{display:flex;gap:16px;flex-wrap:wrap;margin:48px 0 60px;}
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--accent);color:#000;padding:14px 28px;border-radius:8px;font-weight:700;font-size:15px;text-decoration:none;transition:all .3s;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,212,255,0.3);}
.btn-outline{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--text);padding:14px 28px;border-radius:8px;font-weight:600;font-size:15px;text-decoration:none;border:1px solid var(--border);transition:all .3s;}
.btn-outline:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px);}
.nav-projects{display:flex;gap:16px;margin:0 0 60px;padding:28px;background:var(--card);border:1px solid var(--border);border-radius:16px;justify-content:space-between;flex-wrap:wrap;}
.nav-proj-link{text-decoration:none;color:var(--text);font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px;transition:color .3s;}
.nav-proj-link:hover{color:var(--accent);}
@media(max-width:600px){main{padding-left:20px;padding-right:20px;}nav{padding:0 20px;}.cta-row{flex-direction:column;}}
</style>
</head>
